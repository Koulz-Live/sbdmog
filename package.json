{
  "name": "sbdmog",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "api"
  ],
  "scripts": {
    "build": "bash scripts/build.sh",
    "dev": "concurrently \"npm run dev --workspace=apps/web\"",
    "type-check": "tsc --noEmit -p tsconfig.base.json",
    "lint": "eslint \"**/*.{ts,tsx}\" --ignore-pattern \"**/dist/**\" --ignore-pattern \"**/node_modules/**\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5",
    "@types/node": "^20.12.0",
    "eslint": "^9.0.0"
  }
}
