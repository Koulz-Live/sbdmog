{
  "name": "@heqcis/azure-connector",
  "version": "1.0.0",
  "description": "HEQCIS Azure Functions connector — Timer Trigger SQL/Backup/ETL checks pushing HMAC-signed webhooks into the Vercel API layer",
  "private": true,
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc --build",
    "build:watch": "tsc --build --watch",
    "clean": "rimraf dist",
    "start": "npm run build && func start",
    "start:watch": "npm-run-all --parallel build:watch func:start",
    "func:start": "func start",
    "lint": "eslint src --ext .ts",
    "test": "echo \"No tests yet\" && exit 0",
    "predeploy": "npm run build",
    "deploy": "bash scripts/deploy-functionapp.sh"
  },
  "dependencies": {
    "@azure/identity": "^4.4.1",
    "@azure/keyvault-secrets": "^4.8.0",
    "mssql": "^11.0.1",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@azure/functions": "^4.5.1",
    "@types/mssql": "^9.1.5",
    "@types/node": "^20.14.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^5.0.10",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
